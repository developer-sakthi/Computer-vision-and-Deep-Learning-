   "source": [
    "# Given values\n",
    "y = 1\n",
    "y_hat = 0.6\n",
    "w = 0.5\n",
    "x = 2\n",
    "\n",
    "# Compute dL/dy_hat\n",
    "dL_dyhat = -2 * (y - y_hat)\n",
    "\n",
    "# Compute dy_hat/dw\n",
    "dyhat_dw = x\n",
    "\n",
    "# Chain rule: dL/dw\n",
    "dL_dw = dL_dyhat * dyhat_dw\n",
    "\n",
    "# Display results\n",
    "print(\"dL/dŷ =\", dL_dyhat)\n",
    "print(\"dŷ/dw =\", dyhat_dw)\n",
    "print(\"dL/dw =\", dL_dw)"
   ]
